    {"id": 3, "text": "包含TP/EP/DP并行策略配置", "type": "contains"},
    {"id": 4, "text": "提到总卡数需求", "type": "contains"},
    {"id": 5, "text": "包含吞吐量估算", "type": "contains"},
    {"id": 6, "text": "EP值正确（MoE模型需要EP>1）", "type": "contains"},
    {"id": 7, "text": "xPyD计算逻辑正确（若PD分离）", "type": "contains"}
  ]
